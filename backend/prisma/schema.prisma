
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  picture            String?
  googleId           String    @unique
  googleAccessToken  String?   @db.Text
  googleRefreshToken String?   @db.Text
  googleTokenExpiry  DateTime?
  refreshToken       String?   @db.Text

  autoDeleteDays     Int?
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  slackWebhookUrl    String? @db.Text
  jiraDomain         String? @db.Text
  jiraEmail          String? @db.Text
  jiraApiToken       String? @db.Text
  jiraProjectKey     String? @db.Text
  jiraAutoSync       Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime @default(now())

  meetings          Meeting[]
  actionItems       ActionItem[]
  pushSubscriptions PushSubscription[]
  workspaceMemberships WorkspaceMember[]

  @@index([email])
  @@index([googleId])
  @@map("users")
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum MeetingStatus {
  UPLOADING
  PENDING
  PROCESSING_AUDIO
  TRANSCRIBING
  PROCESSING_NLP
  SUMMARIZING
  COMPLETED
  FAILED
}

enum MeetingCategory {
  SALES
  PLANNING
  STANDUP
  ONE_ON_ONE
  RETROSPECTIVE
  INTERVIEW
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Meeting {
  id          String          @id @default(uuid())
  title       String
  description String?         @db.Text
  category    MeetingCategory @default(OTHER)
  status      MeetingStatus   @default(UPLOADING)

  googleEventId String?
  attendees     Json?

  audioUrl      String?
  audioSize     Int?
  audioDuration Float?
  audioFormat   String?

  transcriptText      String? @db.Text
  transcriptSegments  Json?
  speakerMap          Json?
  transcriptWordCount Int?
  transcriptConfidence Float?

  nlpEntities       String? @db.Text
  nlpActionPatterns String? @db.Text
  nlpSentiment      String?
  nlpSentimentScore Float?

  summaryExecutive    String? @db.Text
  summaryKeyDecisions String? @db.Text
  summaryActionItems  Json?
  summaryNextSteps    String? @db.Text
  summaryKeyTopics    Json?
  summarySentiment    String?

  processingError       String?   @db.Text
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  processingDuration    Float?

  retryCount  Int       @default(0)
  queuedAt    DateTime?
  lastRetryAt DateTime?

  audioDeletedAt      DateTime?
  shouldDeleteAudioAt DateTime?

  emailSent   Boolean   @default(false)
  emailSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shareToken    String?   @unique
  shareEnabled  Boolean   @default(false)
  sharedAt      DateTime?

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionItems ActionItem[]
  workspaceMeeting WorkspaceMeeting?

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([shouldDeleteAudioAt])
  @@index([status, queuedAt])
  @@map("meetings")
}

model Workspace {
  id          String             @id @default(uuid())
  name        String
  description String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  members     WorkspaceMember[]
  meetings    WorkspaceMeeting[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceMeeting {
  id          String    @id @default(uuid())
  workspaceId String
  meetingId   String    @unique
  addedAt     DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("workspace_meetings")
}

model ProcessingLog {
  id        String   @id @default(uuid())
  meetingId String
  stage     String
  status    String
  details   Json?
  duration  Float?
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@index([stage])
  @@index([createdAt])
  @@map("processing_logs")
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("user_activities")
}

model ActionItem {
  id          String     @id @default(uuid())
  task        String     @db.Text
  assignee    String?
  deadline    String?
  priority    String?    @default("medium")
  status      TaskStatus @default(TODO)
  confidence  String?    @default("medium")
  sourceQuote String?    @db.Text
  jiraIssueKey String?   @db.Text
  jiraIssueId  String?   @db.Text

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("action_items")
}

model PushSubscription {
  id        String @id @default(uuid())
  endpoint  String @unique
  p256dh    String
  auth      String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}
