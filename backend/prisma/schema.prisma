// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model - Google OAuth only
model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  picture            String? // Google profile picture URL
  googleId           String    @unique
  googleAccessToken  String?   @db.Text
  googleRefreshToken String?   @db.Text
  googleTokenExpiry  DateTime?
  refreshToken       String?   @db.Text // JWT refresh token

  // Settings
  autoDeleteDays     Int? // Auto-delete audio after X days (null = never delete)
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  slackWebhookUrl    String? @db.Text // Slack integration endpoint

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime @default(now())

  // Relations
  meetings          Meeting[]
  actionItems       ActionItem[]
  pushSubscriptions PushSubscription[]
  workspaceMemberships WorkspaceMember[]

  @@index([email])
  @@index([googleId])
  @@map("users")
}

// Workspace role enum
enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

// Meeting status enum
enum MeetingStatus {
  UPLOADING
  PENDING // Queued, waiting for worker
  PROCESSING_AUDIO
  TRANSCRIBING
  PROCESSING_NLP
  SUMMARIZING
  COMPLETED
  FAILED
}

// Meeting category enum
enum MeetingCategory {
  SALES
  PLANNING
  STANDUP
  ONE_ON_ONE
  RETROSPECTIVE
  INTERVIEW
  OTHER
}

// Task status enum
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// Meeting model - Core entity
model Meeting {
  id          String          @id @default(uuid())
  title       String
  description String?         @db.Text
  category    MeetingCategory @default(OTHER)
  status      MeetingStatus   @default(UPLOADING)

  // Google Calendar Integration
  googleEventId String?
  attendees     Json?

  // Audio metadata
  audioUrl      String? // Processed audio URL (Supabase storage)
  audioSize     Int? // File size in bytes
  audioDuration Float? // Duration in seconds (max 180)
  audioFormat   String? // e.g., "mp3", "wav"

  // Processing results - Full transcript with embedded NLP features
  transcriptText      String? @db.Text // Full transcript text (fallback or SpaCy feed)
  transcriptSegments  Json? // Structured arrays of [{start, end, text, speaker}]
  speakerMap          Json? // User-defined speaker names e.g., {"SPEAKER_00": "John"}
  transcriptWordCount Int?
  transcriptConfidence Float? // Average confidence score from transcription model

  // NLP Features (extracted from transcript)
  nlpEntities       String? @db.Text // Named entities (e.g., "John Doe (PERSON), Q4 2024 (DATE)")
  nlpActionPatterns String? @db.Text // Action patterns (e.g., "cut: it, love: you")
  nlpSentiment      String? // Sentiment label (positive/negative/neutral)
  nlpSentimentScore Float? // Sentiment polarity score

  // AI Summary (structured format matching dataset)
  summaryExecutive    String? @db.Text // Executive summary (2-3 sentences)
  summaryKeyDecisions String? @db.Text // Key decisions made
  summaryActionItems  Json? // [{task, assignee?, deadline?, priority?}]
  summaryNextSteps    String? @db.Text // Next steps
  summaryKeyTopics    Json? // Array of key topics from summary
  summarySentiment    String? // Overall sentiment from summary

  // Processing metadata
  processingError       String?   @db.Text
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  processingDuration    Float? // Total processing time in seconds

  // Queue tracking
  retryCount  Int       @default(0) // Number of retry attempts
  queuedAt    DateTime? // When added to queue
  lastRetryAt DateTime? // Last retry attempt timestamp

  // Audio deletion tracking
  audioDeletedAt      DateTime? // When audio was auto-deleted
  shouldDeleteAudioAt DateTime? // Scheduled deletion date

  // Email notification
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Share link feature
  shareToken    String?   @unique
  shareEnabled  Boolean   @default(false)
  sharedAt      DateTime?

  // Relations
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionItems ActionItem[]
  workspaceMeeting WorkspaceMeeting?

  @@index([userId])
  @@index([userId, createdAt]) // composite: list queries sorted by date
  @@index([userId, status])   // composite: count queries filtered by status per user
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([shouldDeleteAudioAt]) // For cron job cleanup
  @@index([status, queuedAt]) // For queue processing
  @@map("meetings")
}

// Workspace model
model Workspace {
  id          String             @id @default(uuid())
  name        String
  description String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  members     WorkspaceMember[]
  meetings    WorkspaceMeeting[]

  @@map("workspaces")
}

// Workspace member model
model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// Workspace meeting link model
model WorkspaceMeeting {
  id          String    @id @default(uuid())
  workspaceId String
  meetingId   String    @unique
  addedAt     DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("workspace_meetings")
}

// Processing log for debugging and analytics
model ProcessingLog {
  id        String   @id @default(uuid())
  meetingId String
  stage     String // "audio", "transcription", "nlp", "summary"
  status    String // "started", "completed", "failed"
  details   Json? // Additional details, errors, metrics
  duration  Float? // Stage duration in seconds
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@index([stage])
  @@index([createdAt])
  @@map("processing_logs")
}

// User activity tracking (optional for analytics)
model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  action    String // "login", "record", "view_meeting", "download"
  metadata  Json? // Additional context
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("user_activities")
}

// ActionItem model - Linked to Meetings and Users for Kanban board
model ActionItem {
  id          String     @id @default(uuid())
  task        String     @db.Text
  assignee    String?
  deadline    String?
  priority    String?    @default("medium")
  status      TaskStatus @default(TODO)
  confidence  String?    @default("medium") // Extraction confidence: high, medium, low
  sourceQuote String?    @db.Text // Transcript citation for grounding verification

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("action_items")
}

// Push subscription for web/mobile notifications
model PushSubscription {
  id        String @id @default(uuid())
  endpoint  String @unique
  p256dh    String
  auth      String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}
